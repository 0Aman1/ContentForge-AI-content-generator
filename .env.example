# Sample Configuration File for AI Content Generation Studio
# Copy this to .env or modify settings.json for persistent settings

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3

# Database Configuration
DB_PATH=content_studio.db
DB_ENABLE_FOREIGN_KEYS=true

# Generation Configuration
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=2000
GENERATION_TIMEOUT=300

# Application Configuration
APP_THEME=light
AUTO_SAVE_HISTORY=true
SESSION_MEMORY_ENABLED=true
DEFAULT_LANGUAGE=English

# Export Configuration
EXPORT_PATH=exports/
EXPORT_FORMAT=txt
INCLUDE_METADATA_DEFAULT=true

# Feature Flags
SHOW_ADVANCED_OPTIONS=false
ENABLE_BULK_OPERATIONS=true
ENABLE_FAVORITES=true
ENABLE_TEMPLATES=true

# Logging Configuration
LOG_LEVEL=INFO
SAVE_LOGS=false
